---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formatDate = (date) => date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
const postViewsBadge = `https://visitor-badge.laobi.icu/badge?page_id=ohrkawk-ojs.github.io.posts.${post.id}`;
---
<BaseLayout
  title={`${post.data.title} — 대기업 직장인의 AX 실험실`}
  description={post.data.summary}
  image={post.data.cover}
  type="article"
>
  <main class="article">
    <a class="button" href="/">← 글 목록</a>
    <div style="margin-top:32px" class="meta article-meta">
      <span>{post.data.category}</span>
      <span>·</span>
      <span>{formatDate(post.data.date)}</span>
      <span>·</span>
      <span class="post-views">
        <span>조회수</span>
        <img src={postViewsBadge} alt={`${post.data.title} 조회수`} loading="lazy" referrerpolicy="no-referrer-when-downgrade" />
      </span>
    </div>
    <h1>{post.data.title}</h1>
    <p class="lead">{post.data.summary}</p>
    <div class="cover" style={post.data.cover ? `border-radius:32px;margin:34px 0;min-height:360px;background-image: linear-gradient(135deg, rgba(15,23,42,.05), rgba(15,23,42,.05)), url('${post.data.cover}');` : 'border-radius:32px;margin:34px 0;min-height:360px'}></div>
    <article class="article-content">
      <Content />
    </article>
    <div class="tags">{post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}</div>
    {post.data.source_urls.length > 0 && (
      <div class="newsletter">
        <div class="label">SOURCE</div>
        <h2>참고 링크</h2>
        <ul>{post.data.source_urls.map((url) => <li><a href={url}>{url}</a></li>)}</ul>
      </div>
    )}
  </main>
</BaseLayout>
