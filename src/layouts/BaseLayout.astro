---
import '../styles/global.css';

const {
  title = '대기업 직장인의 AX 실험실',
  description = '대기업 직장인이 AI, AX, Agentic AI, 업무자동화 뉴스를 해석하고 기업 업무 프로세스, 결재선, 데이터 권한 관점에서 정리하는 기술 블로그입니다.',
  image = '/images/covers/agentic-ai-operating-system.jpg',
  type = 'website',
} = Astro.props;

const site = Astro.site ?? new URL('https://ohrkawk-ojs.github.io');
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const imageUrl = image?.startsWith('http') ? image : new URL(image, site).toString();
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content="대기업 직장인의 AX 실험실" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {image && <meta property="og:image" content={imageUrl} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={imageUrl} />}

    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="logo" href="/">
          <span class="logo-mark">AX</span>
          <span>대기업 직장인의 AX 실험실</span>
        </a>
        <nav class="nav-links">
          <a href="/">홈</a>
          <a href="/about">소개</a>
          <a href="https://github.com/ohrkawk-ojs/ohrkawk-ojs.github.io">GitHub</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="container nav">
        <a class="logo" href="/"><span class="logo-mark">AX</span><span>AX 실험실</span></a>
        <div class="footer-meta">
          <nav class="nav-links">
            <a href="/">홈</a>
            <a href="/about">소개</a>
            <a href="https://github.com/ohrkawk-ojs/ohrkawk-ojs.github.io">GitHub</a>
          </nav>
          <a class="visitor-counter" href="https://hits.seeyoufarm.com" target="_blank" rel="noopener noreferrer" aria-label="방문자수 카운터">
            <span>방문자수</span>
            <img src="https://hits.seeyoufarm.com/api/count/incr/badge.svg?url=https%3A%2F%2Fohrkawk-ojs.github.io&count_bg=%237DD3FC&title_bg=%23111827&icon=&icon_color=%23E7E7E7&title=visits&edge_flat=false" alt="방문자수" loading="lazy" referrerpolicy="no-referrer-when-downgrade" />
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
